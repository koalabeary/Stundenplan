<Window x:Class="Stundenplan.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Stundenplan"
        mc:Ignorable="d"
        Title="Stundenplan Designer" Height="1000" Width="1500" Background="#F2F2F7">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="20,15" BorderBrush="#D1D1D6" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Stundenplan" FontSize="22" FontWeight="Bold" Foreground="#1C1C1E" VerticalAlignment="Center" Margin="0,0,50,0"/>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                    <TextBlock Text="Von:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#8E8E93" FontSize="14"/>
                    <TextBox Name="Start" Width="70" Padding="8,5" VerticalContentAlignment="Center" BorderBrush="#C7C7CC" BorderThickness="1">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                    <TextBlock Text="Bis:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#8E8E93" FontSize="14"/>
                    <TextBox Name="Ende" Width="70" Padding="8,5" VerticalContentAlignment="Center" BorderBrush="#C7C7CC" BorderThickness="1">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                    <TextBlock Text="Titel:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#8E8E93" FontSize="14"/>
                    <TextBox Name="Titel" Width="150" Padding="8,5" VerticalContentAlignment="Center" BorderBrush="#C7C7CC" BorderThickness="1">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                </StackPanel>
                
                <Button Name="Erstellen" Content="Plan generieren" Margin="40,0,0,0" Padding="25,10" 
                        Background="#007AFF" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Click="Erstellen_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#FFFFFF" Padding="20,10" BorderBrush="#D1D1D6" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Name="BtnFachHinzufuegen" Grid.Column="0" Content="+ Fach hinzufügen" 
                        Padding="20,12" Background="#34C759" Foreground="White" 
                        FontWeight="Bold" FontSize="14" BorderThickness="0" Click="BtnFachHinzufuegen_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Rectangle Grid.Column="1" Width="1" Fill="#D1D1D6" Margin="20,5"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="Bibliothek:" VerticalAlignment="Center" Foreground="#8E8E93" Margin="0,0,15,0" FontWeight="Medium"/>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl Name="FaecherLeiste">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="#EBEDF0">
                <Border x:Name="PapierBorder"
        Width="1122" 
        Height="Auto"  Background="White" 
        Margin="50" 
        HorizontalAlignment="Center" 
        VerticalAlignment="Top"
        BorderBrush="#D1D1D6"
        BorderThickness="1">

                    <Canvas x:Name="Leinwand" Width="1122">
                    </Canvas>
                </Border>
            </ScrollViewer>

            <Border VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,30,30" Background="#CCFFFFFF" Padding="10,5" CornerRadius="5">
                <TextBlock Text="Format: DIN-A4 Quer" Foreground="#3A3A3C" FontSize="12" FontWeight="Medium"/>
            </Border>
        </Grid>
    </Grid>
</Window>